<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.uge.but.schtroumpf.controller.MainMenuController"
            styleClass="menu-root">
    <center>
        <VBox alignment="CENTER" spacing="24" maxWidth="620" styleClass="menu-panel">
            <padding>
                <Insets top="48" right="56" bottom="48" left="56"/>
            </padding>
            <Label text="Conseil des Schtroumpfs" styleClass="main-title"/>
            <Label text="Manage the Smurfs council for 12 months. Produce resources, face forest events, choose council actions, and avoid three simultaneous crises."
                   wrapText="true"
                   styleClass="menu-text"/>
            <VBox alignment="CENTER" spacing="12">
                <Button text="Start Game" onAction="#handleStartGame" styleClass="primary-button"/>
                <Button text="Quit" onAction="#handleQuit" styleClass="secondary-button"/>
            </VBox>
        </VBox>
    </center>
</BorderPane>
